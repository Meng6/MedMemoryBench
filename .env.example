# ============================================================================
# LLM API Configuration
# ============================================================================
# OpenAI-compatible API (default)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_BASE=https://api.openai.com/v1
DEFAULT_LLM_MODEL=gpt-4o

# ChatGLM BigModel API (optional, for GLM series models)
# BIGMODEL_API_KEY=your_bigmodel_api_key_here
# BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Azure OpenAI API (optional)
# AZURE_OPENAI_API_KEY=your_azure_api_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name

# ============================================================================
# Judge Model Settings (for evaluation metrics)
# ============================================================================
# The judge model is used by the evaluation pipeline to score agent responses.
# It can be different from the main LLM model.
JUDGE_MODEL=gpt-4o
JUDGE_API_KEY=your_judge_api_key
JUDGE_BASE_URL=https://api.openai.com/v1

# ============================================================================
# Embedding Settings
# ============================================================================
# Option 1: OpenAI Embedding API
# DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_PROVIDER=openai

# Option 2: Local Embedding Model (recommended for reproducibility)
DEFAULT_EMBEDDING_MODEL=/path/to/your/local/embedding/model
EMBEDDING_PROVIDER=local

# ============================================================================
# Zep Cloud Configuration (required for Zep method evaluation)
# ============================================================================
# ZEP_API_KEY=your_zep_api_key

# ============================================================================
# General Settings
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# MIRIX Configuration (required for MIRIX method evaluation)
# ============================================================================
# PostgreSQL Database (required for MIRIX)
# Start the database service first:
#   ./scripts/mirix-services.sh start
MIRIX_PG_USER=mirix
MIRIX_PG_PASSWORD=mirix
MIRIX_PG_DB=mirix
MIRIX_PG_HOST=localhost
MIRIX_PG_PORT=5432
# Full URI (overrides individual settings if set)
# MIRIX_PG_URI=postgresql+pg8000://mirix:mirix@localhost:5432/mirix

# Redis Configuration (optional, improves MIRIX performance)
# To enable Redis, set MIRIX_REDIS_ENABLED=true and run:
#   ./scripts/mirix-services.sh start-all
MIRIX_REDIS_ENABLED=false
MIRIX_REDIS_HOST=localhost
MIRIX_REDIS_PORT=6379

MIRIX_LOG_LEVEL=INFO
