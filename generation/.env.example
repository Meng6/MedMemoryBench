OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_BASE=https://api.openai.com/v1

# For Azure OpenAI (optional)
# AZURE_API_KEY=your-azure-api-key
# AZURE_API_BASE=https://your-resource.openai.azure.com

# For other providers, see LiteLLM documentation
# https://docs.litellm.ai/docs/providers

# Default model to use
LLM_MODEL=gpt-4o
LLM_MODEL_SMALL=gpt-4o
LLM_TIMEOUT=300  # LLM request timeout in seconds, auto-retry on timeout (max 10 retries)

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/med_eve.db

# Server
HOST=0.0.0.0
PORT=8000
